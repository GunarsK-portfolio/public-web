{
  "name": "public-web",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@iconify-json/logos": "^1.2.10",
    "@unhead/vue": "^2.1.12",
    "@vicons/ionicons5": "^0.13.0",
    "axios": "^1.13.6",
    "dompurify": "^3.3.1",
    "marked": "^17.0.4",
    "mermaid": "^11.12.2",
    "naive-ui": "^2.44.1",
    "pino": "^10.3.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=24.14.0",
    "npm": ">=11.11.1"
  }
}
